# IMPORTANT
# - Do NOT store real secrets in the repository.
# - In production, copy this file to: /etc/reality-autorotate.env (chmod 600)
# - Keep autorotate/.env local-only (gitignored) if you use it for dev.

# Marzban
MARZBAN_URL="http://127.0.0.1:27500"
MARZBAN_USER=""
MARZBAN_PASS=""
XRAY_INBOUND_TAG="VLESS_REALITY"

# Paths
PROJECT_ROOT="/path/to/realityscanner"

# State
STATE_DIR="/var/lib/reality-autorotate"

# Rotate
DEST_FAIL_COUNT=5
ROTATE_COOLDOWN=300
VERIFY_TIMEOUT=5

# Scanner
# offline: no git/go build/update in pipeline (recommended for systemd)
# managed: pipeline may update/build upstream (use only for manual runs)
SCANNER_MODE="offline"

# scan_pick pipeline logging
# scan_pick.sh captures pipeline stdout/stderr into: ${STATE_DIR}/scan_pick.pipeline.log
# and rotates it (best-effort) if it grows beyond SCAN_PICK_LOG_MAX_BYTES.
SCAN_PICK_LOG_MAX_BYTES=1048576  # 1 MiB
SCAN_PICK_LOG_KEEP=5

# Telegram
TG_TOKEN=""
TG_ID=""
